{
  "hosting": {
    "public": "ballot",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase",
      ".gitignore",
      "node_modules",
      "README.md",
      "**/.*"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  }
}
